---
import { getLangFromUrl, t } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import UserMenu from '../components/UserMenu.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const lang: Lang = getLangFromUrl(Astro.url) ?? defaultLang;
const currentPath = Astro.url.pathname;

const pageTitle = Astro.props.title ?? t(lang, 'site.title');
const description = Astro.props.description ?? t(lang, 'site.tagline');

const navItems: Array<{ key: any; href: string }> = [
  { key: 'nav.home', href: lang === defaultLang ? '/' : `/${lang}` },
  { key: 'nav.posts', href: lang === defaultLang ? '/posts' : `/${lang}/posts` },
  { key: 'nav.projects', href: lang === defaultLang ? '/projects' : `/${lang}/projects` },
];

const year = new Date().getFullYear();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- No-FOUC theme script: applies saved/system theme before paint. -->
    <script is:inline>
      (function () {
        try {
          const stored = localStorage.getItem('theme');
          const systemDark = window.matchMedia(
            '(prefers-color-scheme: dark)'
          ).matches;
          if (stored === 'dark' || (!stored && systemDark)) {
            document.documentElement.classList.add('dark');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={navItems[0].href} class="brand">
          {t(lang, 'site.title')}
        </a>
        <nav class="site-nav" aria-label="Primary">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                aria-current={currentPath === item.href ? 'page' : undefined}
              >
                {t(lang, item.key)}
              </a>
            ))
          }
        </nav>
        <div class="header-actions">
          <LanguageSwitcher lang={lang} currentPath={currentPath} />
          <ThemeToggle />
          <UserMenu />
        </div>
      </div>
    </header>

    <main id="main" class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-col">
          <span>
            © {year} {t(lang, 'site.title')}. {t(lang, 'footer.rights')}
          </span>
          <span class="built-with">
            {t(lang, 'footer.built_with')}
          </span>
        </div>
      </div>
    </footer>

    <!-- Theme toggle handler. Full persistence expanded in Schritt 5. -->
    <script is:inline>
      (function () {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', function () {
          const isDark = document.documentElement.classList.toggle('dark');
          try {
            localStorage.setItem('theme', isDark ? 'dark' : 'light');
          } catch (e) {}
        });
      })();
    </script>
  </body>
</html>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background-color: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    gap: var(--space);
    min-height: 4rem;
  }
  .brand {
    font-weight: 700;
    font-size: 1.125rem;
    color: var(--color-text);
  }
  .brand:hover {
    text-decoration: none;
    color: var(--color-accent);
  }
  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-inline-start: auto;
  }
  .site-nav a {
    color: var(--color-muted);
    font-size: 0.95rem;
    padding: 0.25rem 0.5rem;
  }
  .site-nav a:hover,
  .site-nav a[aria-current='page'] {
    color: var(--color-text);
    text-decoration: none;
  }
  .site-nav a[aria-current='page'] {
    border-bottom: 2px solid var(--color-accent);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--color-border);
    padding-block: 1.5rem;
    color: var(--color-muted);
    font-size: 0.875rem;
  }
  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  @media (max-width: 640px) {
    .site-nav {
      margin-inline-start: 0;
      width: 100%;
    }
    .header-inner {
      flex-wrap: wrap;
    }
    .header-actions {
      margin-inline-start: auto;
    }
  }
</style>
