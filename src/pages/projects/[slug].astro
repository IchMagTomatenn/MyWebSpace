---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectDetail from '../../components/ProjectDetail.astro';
import { getCollection } from 'astro:content';
import { getProjectBySlug, projectSlug } from '../../lib/projects';
import { defaultLang } from '../../i18n/ui';

export async function getStaticPaths() {
  const all = await getCollection('projects');
  return all
    .filter((entry) => entry.data.lang === defaultLang)
    .map((entry) => ({
      params: { slug: projectSlug(entry) },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const project = await getProjectBySlug(projectSlug(entry), defaultLang);
---

<BaseLayout title={project?.data.title} description={project?.data.description}>
  {project && <ProjectDetail project={project} />}
</BaseLayout>
