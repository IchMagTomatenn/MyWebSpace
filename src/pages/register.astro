---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, t } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url) ?? defaultLang;
const l = (path: string) => (lang === defaultLang ? path : `/${lang}${path}`);
---

<BaseLayout title={t(lang, 'auth.register.title')}>
  <section style="padding-block: clamp(2rem, 6vw, 4rem);">
    <form id="register-form" class="card" novalidate>
      <h1>{t(lang, 'auth.register.title')}</h1>
      <p class="subtitle">{t(lang, 'auth.register.subtitle')}</p>

      <div class="field">
        <label for="name">{t(lang, 'auth.name')}</label>
        <input id="name" name="name" type="text" autocomplete="name" required />
      </div>
      <div class="field">
        <label for="email">{t(lang, 'auth.email')}</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="field">
        <label for="password">{t(lang, 'auth.password')}</label>
        <input id="password" name="password" type="password" autocomplete="new-password" required minlength="8" />
      </div>
      <div class="field">
        <label for="password2">{t(lang, 'auth.password_confirm')}</label>
        <input id="password2" name="password2" type="password" autocomplete="new-password" required />
      </div>
      <div class="form-actions">
        <button class="btn btn-primary" type="submit">{t(lang, 'auth.submit.register')}</button>
      </div>
      <p id="msg" class="form-msg error" hidden></p>
      <p class="auth-alt form-meta">
        {t(lang, 'auth.have_account')} <a href={l('/login')}>{t(lang, 'nav.login')}</a>
      </p>
    </form>
  </section>

  <span id="i18n" class="visually-hidden" data-generic={t(lang, 'auth.error.generic')} data-required={t(lang, 'auth.error.required')} data-mismatch={t(lang, 'auth.error.password_mismatch')} data-verify={l('/verify-email')}></span>

  <script>
    import { authClient } from '../lib/auth-client';
    const i18n = document.getElementById('i18n')!.dataset as Record<string, string>;
    const form = document.getElementById('register-form')! as HTMLFormElement;
    const msg = document.getElementById('msg')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.hidden = true;
      const data = new FormData(form);
      const name = String(data.get('name') ?? '').trim();
      const email = String(data.get('email') ?? '').trim();
      const password = String(data.get('password') ?? '');
      const password2 = String(data.get('password2') ?? '');
      if (!name || !email || !password) {
        msg.textContent = i18n.required;
        msg.hidden = false;
        return;
      }
      if (password !== password2) {
        msg.textContent = i18n.mismatch;
        msg.hidden = false;
        return;
      }
      try {
        const origin = window.location.origin;
        const res = await authClient.signUp.email({
          email,
          password,
          name,
          callbackURL: `${origin}/login?verified=1`,
        });
        if (res.error) {
          msg.textContent = res.error.message ?? i18n.generic;
          msg.hidden = false;
          return;
        }
        window.location.href = i18n.verify;
      } catch (err) {
        msg.textContent = i18n.generic;
        msg.hidden = false;
      }
    });
  </script>
</BaseLayout>
