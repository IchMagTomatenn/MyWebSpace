---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, t } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url) ?? defaultLang;
const l = (path: string) => (lang === defaultLang ? path : `/${lang}${path}`);
---

<BaseLayout title={t(lang, 'auth.forgot.title')}>
  <section style="padding-block: clamp(2rem, 6vw, 4rem);">
    <form id="forgot-form" class="card" novalidate>
      <h1>{t(lang, 'auth.forgot.title')}</h1>
      <p class="subtitle">{t(lang, 'auth.forgot.body')}</p>

      <div class="field">
        <label for="email">{t(lang, 'auth.email')}</label>
        <input id="email" name="email" type="email" autocomplete="email" required />
      </div>
      <div class="form-actions">
        <button class="btn btn-primary" type="submit">{t(lang, 'auth.forgot.title')}</button>
      </div>
      <p id="msg" class="form-msg success" hidden></p>
      <p class="auth-alt form-meta">
        <a href={l('/login')}>{t(lang, 'nav.login')}</a>
      </p>
    </form>
  </section>

  <span id="i18n" class="visually-hidden" data-generic={t(lang, 'auth.error.generic')} data-sent={t(lang, 'auth.forgot.sent')}></span>

  <script>
    import { authClient } from '../lib/auth-client';
    const i18n = document.getElementById('i18n')!.dataset as Record<string, string>;
    const form = document.getElementById('forgot-form')! as HTMLFormElement;
    const msg = document.getElementById('msg')!;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.hidden = true;
      const email = String(new FormData(form).get('email') ?? '').trim();
      if (!email) return;
      try {
        const origin = window.location.origin;
        await authClient.requestPasswordReset({
          email,
          redirectTo: `${origin}/reset-password`,
        });
        // Always show the neutral "sent" message to avoid leaking whether an
        // account exists for the entered email.
        msg.textContent = i18n.sent;
        msg.classList.remove('error');
        msg.classList.add('success');
        msg.hidden = false;
      } catch (err) {
        msg.textContent = i18n.generic;
        msg.classList.add('error');
        msg.classList.remove('success');
        msg.hidden = false;
      }
    });
  </script>
</BaseLayout>
