---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, t } from '../../i18n/utils';
import { defaultLang, type Lang } from '../../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url) ?? defaultLang;
const l = (path: string) => (lang === defaultLang ? path : `/${lang}${path}`);

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect(l('/login'));
}

const welcome = t(lang, 'dashboard.welcome').replace('{name}', user.name);
---

<BaseLayout title={t(lang, 'dashboard.title')}>
  <section style="padding-block: 2rem;">
    <h1>{welcome}</h1>
    <p style="color: var(--color-muted); margin-top: 0;">{t(lang, 'dashboard.subtitle')}</p>

    <div class="dash-grid">
      <div class="dash-card">
        <h2>{t(lang, 'dashboard.my_projects')}</h2>
        <p class="empty">{t(lang, 'dashboard.no_projects')}</p>
        <a class="btn btn-primary" href={l('/dashboard/projects/new')}>{t(lang, 'dashboard.new_project')}</a>
      </div>
      <div class="dash-card">
        <h2>{t(lang, 'dashboard.my_posts')}</h2>
        <p class="empty">{t(lang, 'dashboard.no_posts')}</p>
        <div class="card-actions">
          <a class="btn btn-ghost" href={l('/dashboard/posts')}>{t(lang, 'posts.my')}</a>
          <a class="btn btn-primary" href={l('/dashboard/posts/new')}>{t(lang, 'dashboard.new_post')}</a>
        </div>
      </div>
      <div class="dash-card">
        <h2>{t(lang, 'dashboard.edit_profile')}</h2>
        <a class="btn btn-ghost" href={l('/dashboard/profile')}>{t(lang, 'dashboard.edit_profile')}</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .dash-grid {
    margin-top: 1.5rem;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
  }
  .dash-card {
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .dash-card h2 {
    margin: 0;
    font-size: 1.1rem;
  }
  .empty {
    color: var(--color-muted);
    font-size: 0.9rem;
    margin: 0;
  }
  .card-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: auto;
  }
</style>
