---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogDetail from '../../../components/BlogDetail.astro';
import { getCollection } from 'astro:content';
import { getPostBySlug, blogSlug } from '../../../lib/blog';
import { type Lang } from '../../../i18n/ui';

export async function getStaticPaths() {
  const lang: Lang = 'en';
  const all = await getCollection('blog');
  return all
    .filter((entry) => entry.data.lang === lang)
    .map((entry) => ({
      params: { slug: blogSlug(entry) },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const post = await getPostBySlug(blogSlug(entry), 'en');
---

<BaseLayout title={post?.data.title} description={post?.data.description}>
  {post && <BlogDetail post={post} />}
</BaseLayout>
