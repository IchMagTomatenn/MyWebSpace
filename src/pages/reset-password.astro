---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLangFromUrl, t } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url) ?? defaultLang;
const l = (path: string) => (lang === defaultLang ? path : `/${lang}${path}`);
---

<BaseLayout title={t(lang, 'auth.reset.title')}>
  <section style="padding-block: clamp(2rem, 6vw, 4rem);">
    <form id="reset-form" class="card" novalidate>
      <h1>{t(lang, 'auth.reset.title')}</h1>
      <p class="subtitle">{t(lang, 'auth.reset.body')}</p>

      <div class="field">
        <label for="password">{t(lang, 'auth.password')}</label>
        <input id="password" name="password" type="password" autocomplete="new-password" required minlength="8" />
      </div>
      <div class="field">
        <label for="password2">{t(lang, 'auth.password_confirm')}</label>
        <input id="password2" name="password2" type="password" autocomplete="new-password" required />
      </div>
      <div class="form-actions">
        <button class="btn btn-primary" type="submit">{t(lang, 'auth.reset.title')}</button>
      </div>
      <p id="msg" class="form-msg error" hidden></p>
      <p class="auth-alt form-meta">
        <a href={l('/login')}>{t(lang, 'nav.login')}</a>
      </p>
    </form>
  </section>

  <span id="i18n" class="visually-hidden" data-generic={t(lang, 'auth.error.generic')} data-required={t(lang, 'auth.error.required')} data-mismatch={t(lang, 'auth.error.password_mismatch')} data-invalid={t(lang, 'auth.reset.invalid')} data-login={l('/login?reset=1')}></span>

  <script>
    import { authClient } from '../lib/auth-client';
    const i18n = document.getElementById('i18n')!.dataset as Record<string, string>;
    const form = document.getElementById('reset-form')! as HTMLFormElement;
    const msg = document.getElementById('msg')!;
    const submitBtn = form.querySelector('button[type="submit"]')! as HTMLButtonElement;

    const token = new URLSearchParams(location.search).get('token');
    if (!token) {
      msg.textContent = i18n.invalid;
      msg.hidden = false;
      submitBtn.disabled = true;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.hidden = true;
      const data = new FormData(form);
      const password = String(data.get('password') ?? '');
      const password2 = String(data.get('password2') ?? '');
      if (!password) {
        msg.textContent = i18n.required;
        msg.hidden = false;
        return;
      }
      if (password !== password2) {
        msg.textContent = i18n.mismatch;
        msg.hidden = false;
        return;
      }
      try {
        const res = await authClient.resetPassword({ newPassword: password, token: token ?? undefined });
        if (res.error) {
          msg.textContent = res.error.message ?? i18n.generic;
          msg.hidden = false;
          return;
        }
        window.location.href = i18n.login;
      } catch (err) {
        msg.textContent = i18n.generic;
        msg.hidden = false;
      }
    });
  </script>
</BaseLayout>
