---
import { type ProjectEntry, projectHref, projectSlug } from '../lib/projects';
import { defaultLang, type Lang } from '../i18n/ui';

interface Props {
  project: ProjectEntry;
  lang: Lang;
}

const { project, lang } = Astro.props;
const slug = projectHref(projectSlug(project), lang);
const { title, description, tags, date } = project.data;
const locale = lang === defaultLang ? 'de-DE' : 'en-US';
---

<article class="card">
  <a class="card-link" href={slug}>
    <h3>{title}</h3>
    <p class="desc">{description}</p>
    {
      tags.length > 0 && (
        <ul class="tags">
          {tags.map((tag) => (
            <li class="tag">{tag}</li>
          ))}
        </ul>
      )
    }
    <time class="date" datetime={date.toISOString()}>
      {new Intl.DateTimeFormat(locale, {
        year: 'numeric',
        month: 'short',
        day: 'numeric',
      }).format(date)}
    </time>
  </a>
</article>

<style>
  .card {
    display: flex;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.04);
    transition: transform var(--transition), border-color var(--transition),
      box-shadow var(--transition);
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }
  .card-link {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.25rem;
    color: var(--color-text);
    width: 100%;
  }
  .card-link:hover {
    text-decoration: none;
  }
  h3 {
    margin: 0;
    font-size: 1.15rem;
  }
  .desc {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
    flex: 1;
  }
  .tags {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .tag {
    font-size: 0.75rem;
    padding: 0.15rem 0.5rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-muted);
  }
  .date {
    font-size: 0.8rem;
    color: var(--color-muted);
    margin-top: auto;
  }
</style>
