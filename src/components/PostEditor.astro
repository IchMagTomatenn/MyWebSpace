---
import { getLangFromUrl, t } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';
import { supportedLocales } from '../config';
import type { TranslationRow } from '../lib/posts';

/**
 * Multi-language blog post editor.
 *
 * Shared by `/dashboard/posts/new` (empty) and `/dashboard/posts/[id]/edit`
 * (prefilled). Renders a cover uploader, a slug field, a tab per supported
 * language (title / excerpt / content-Markdown) and Save-as-draft +
 * Publish actions (plus Delete in edit mode). The client script gathers the
 * fields, calls `/api/posts` (POST) or `/api/posts/:id` (PATCH/DELETE) and
 * redirects back to the post list.
 *
 * The server passes in the prefilled values; the script reads them from the
 * rendered DOM — the same pattern used by the profile editor.
 */

interface Props {
  mode: 'new' | 'edit';
  postId?: string | null;
  slug?: string;
  coverUrl?: string | null;
  published?: boolean;
  translations?: TranslationRow[];
}

const lang: Lang = getLangFromUrl(Astro.url) ?? defaultLang;
const l = (path: string) => (lang === defaultLang ? path : `/${lang}${path}`);

const {
  mode,
  postId = null,
  slug = '',
  coverUrl = null,
  published = false,
  translations = [],
} = Astro.props;

// Turn the translation rows into a { lang: { title, excerpt, content } } map.
const trMap: Record<string, { title: string; excerpt: string; content: string }> = {};
for (const tr of translations) {
  trMap[tr.lang] = { title: tr.title, excerpt: tr.excerpt, content: tr.content };
}

// Languages shown as tabs. Defined by the site's supported locales.
const tabs = supportedLocales.map((code) => ({
  code,
  label: code === 'de' ? 'Deutsch' : code === 'en' ? 'English' : code,
}));
const initialTab = trMap[lang] ? lang : tabs[0].code;

const isEdit = mode === 'edit';
const title = isEdit ? t(lang, 'posts.editor.edit_title') : t(lang, 'posts.editor.new_title');
const subtitle = t(lang, 'posts.editor.subtitle');
const statusLabel = published ? t(lang, 'posts.status.published') : t(lang, 'posts.status.draft');
---

<form id="post-editor" class="editor" novalidate
  data-mode={mode}
  data-id={postId ?? ''}
  data-back={l('/dashboard/posts')}
>
  <header class="editor-head">
    <h1>
      {title}
      {isEdit && (
        <span class={'badge ' + (published ? 'badge-pub' : 'badge-draft')}>{statusLabel}</span>
      )}
    </h1>
    <p class="subtitle">{subtitle}</p>
  </header>

  <p id="msg" class="form-msg error" hidden></p>

  <!-- Cover -->
  <div class="field cover-field">
    <label>{t(lang, 'posts.editor.cover')}</label>
    <div class="cover-row">
      <div class="cover-preview" id="cover-preview">
        {coverUrl ? (
          <img id="cover-img" src={coverUrl} alt="" />
        ) : (
          <span id="cover-fallback" class="cover-fallback">—</span>
        )}
      </div>
      <div class="cover-controls">
        <label class="btn btn-ghost btn-sm">
          <span>{t(lang, 'posts.editor.cover.change')}</span>
          <input id="cover-file" type="file" accept="image/png,image/jpeg,image/webp,image/gif" hidden />
        </label>
        {coverUrl && (
          <button id="cover-remove" type="button" class="btn btn-ghost btn-sm">{t(lang, 'posts.editor.cover.remove')}</button>
        )}
        <input id="cover-url" type="hidden" value={coverUrl ?? ''} />
        <p id="cover-msg" class="form-msg error" hidden></p>
      </div>
    </div>
  </div>

  <!-- Slug -->
  <div class="field">
    <label for="slug">{t(lang, 'posts.editor.slug')}</label>
    <div class="slug-row">
      <input id="slug" name="slug" type="text" value={slug}
        placeholder={t(lang, 'posts.editor.slug.placeholder')} />
      <button id="slug-auto" type="button" class="btn btn-ghost btn-sm" title={t(lang, 'posts.editor.slug')}>
        ↻
      </button>
    </div>
    <p class="hint">{t(lang, 'posts.editor.slug.hint')}</p>
  </div>

  <!-- Language tabs -->
  <div class="tabs" role="tablist" aria-label={t(lang, 'posts.editor.lang')}>
    {tabs.map((tab) => (
      <button type="button" role="tab"
        class={'tab' + (tab.code === initialTab ? ' active' : '')}
        data-lang={tab.code}
        aria-selected={tab.code === initialTab ? 'true' : 'false'}
      >{tab.label}</button>
    ))}
  </div>

  {tabs.map((tab) => {
    const v = trMap[tab.code] ?? { title: '', excerpt: '', content: '' };
    return (
      <fieldset class={'lang-panel' + (tab.code === initialTab ? '' : ' hidden')} data-lang={tab.code}>
        <div class="field">
          <label for={`title-${tab.code}`}>{t(lang, 'posts.editor.title')}</label>
          <input id={`title-${tab.code}`} data-lang={tab.code} data-field="title" type="text"
            value={v.title} maxlength="200" />
        </div>
        <div class="field">
          <label for={`excerpt-${tab.code}`}>{t(lang, 'posts.editor.excerpt')}</label>
          <textarea id={`excerpt-${tab.code}`} data-lang={tab.code} data-field="excerpt" rows="3"
            maxlength="500">{v.excerpt}</textarea>
        </div>
        <div class="field">
          <label for={`content-${tab.code}`}>{t(lang, 'posts.editor.content')}</label>
          <textarea id={`content-${tab.code}`} data-lang={tab.code} data-field="content" rows="14"
            class="mono" maxlength="100000">{v.content}</textarea>
        </div>
      </fieldset>
    );
  })}

  <div class="form-actions">
    <div class="action-row">
      <button class="btn btn-ghost" type="submit" data-action="draft">
        {t(lang, 'posts.editor.save_draft')}
      </button>
      <button class="btn btn-primary" type="submit" data-action="publish">
        {t(lang, 'posts.editor.publish')}
      </button>
      {isEdit && (
        <button class="btn btn-ghost del" type="button" id="delete-btn">
          {t(lang, 'posts.editor.delete')}
        </button>
      )}
    </div>
    <p class="form-meta"><a href={l('/dashboard/posts')}>{t(lang, 'posts.back')}</a></p>
  </div>
</form>

<span id="i18n" class="visually-hidden"
  data-generic={t(lang, 'auth.error.generic')}
  data-required={t(lang, 'posts.error.title_required')}
  data-slug-required={t(lang, 'posts.error.slug_required')}
  data-slug-invalid={t(lang, 'posts.error.slug_invalid')}
  data-slug-taken={t(lang, 'posts.error.slug_taken')}
  data-not-found={t(lang, 'posts.error.not_found')}
  data-failed={t(lang, 'posts.error.failed')}
  data-confirm-delete={t(lang, 'posts.confirm_delete')}
  data-size={t(lang, 'upload.error.size')}
  data-type={t(lang, 'upload.error.type')}
  data-no-file={t(lang, 'upload.error.no_file')}
  data-upload-failed={t(lang, 'upload.error.failed')}
></span>

<script>
  const i18n = document.getElementById('i18n')!.dataset as Record<string, string>;
  const form = document.getElementById('post-editor')! as HTMLFormElement;
  const msg = document.getElementById('msg')!;
  const mode = form.dataset.mode!;
  const postId = form.dataset.id!;
  const back = form.dataset.back!;

  const errOf = (key: string) => {
    const map: Record<string, string> = {
      'posts.error.title_required': i18n.required,
      'posts.error.slug_required': i18n['slug-required'],
      'posts.error.slug_invalid': i18n['slug-invalid'],
      'posts.error.slug_taken': i18n['slug-taken'],
      'posts.error.not_found': i18n['not-found'],
      'posts.error.failed': i18n.failed,
      unauthorized: i18n.generic,
      invalid: i18n.generic,
    };
    return map[key] ?? i18n.generic;
  };
  const showErr = (key: string) => { msg.textContent = errOf(key); msg.hidden = false; };

  // ---- Tabs ----
  const tabs = Array.from(form.querySelectorAll<HTMLButtonElement>('.tab'));
  const panels = Array.from(form.querySelectorAll<HTMLFieldSetElement>('.lang-panel'));
  tabs.forEach((btn) => {
    btn.addEventListener('click', () => {
      const code = btn.dataset.lang!;
      tabs.forEach((t) => {
        const on = t === btn;
        t.classList.toggle('active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
      });
      panels.forEach((p) => p.classList.toggle('hidden', p.dataset.lang !== code));
    });
  });

  // ---- Slug auto-generate ----
  const slugInput = document.getElementById('slug')! as HTMLInputElement;
  const slugAuto = document.getElementById('slug-auto')!;
  const titleEls = tabs.map((t) =>
    document.querySelector<HTMLInputElement>(`input[data-lang="${t.dataset.lang}"][data-field="title"]`)
  );
  const slugify = (s: string) =>
    s.toLowerCase().normalize('NFKD').replace(/[\u0300-\u036f]/g, '')
      .replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 80) || 'untitled';
  slugAuto.addEventListener('click', () => {
    const firstTitle = titleEls.map((e) => e?.value ?? '').find((v) => v.trim() !== '') ?? '';
    slugInput.value = slugify(firstTitle);
  });

  // ---- Cover upload ----
  const coverFile = document.getElementById('cover-file')! as HTMLInputElement;
  const coverUrl = document.getElementById('cover-url')! as HTMLInputElement;
  const coverPreview = document.getElementById('cover-preview')!;
  const coverMsg = document.getElementById('cover-msg')!;
  const coverRemove = document.getElementById('cover-remove') as HTMLButtonElement | null;

  const renderCover = (url: string | null) => {
    coverPreview.innerHTML = url
      ? `<img src="${url}" alt="" />`
      : `<span class="cover-fallback">—</span>`;
    coverUrl.value = url ?? '';
    if (coverRemove) coverRemove.hidden = url === null || url === '';
  };

  coverFile.addEventListener('change', async () => {
    coverMsg.hidden = true;
    const file = coverFile.files?.[0];
    if (!file) return;
    const fd = new FormData();
    fd.append('file', file);
    try {
      const res = await fetch('/api/upload', { method: 'POST', body: fd });
      const data = await res.json().catch(() => ({}));
      if (!res.ok || !data.url) {
        const key = res.status === 413 ? 'size' : res.status === 415 ? 'type' : 'upload-failed';
        coverMsg.textContent = i18n[key] ?? i18n['upload-failed'];
        coverMsg.hidden = false;
        return;
      }
      renderCover(data.url);
    } catch (e) {
      coverMsg.textContent = i18n['upload-failed'];
      coverMsg.hidden = false;
    } finally {
      coverFile.value = '';
    }
  });
  coverRemove?.addEventListener('click', () => renderCover(null));

  // ---- Gather translations ----
  const gather = () => {
    const translations: Record<string, { title: string; excerpt: string; content: string }> = {};
    panels.forEach((p) => {
      const code = p.dataset.lang!;
      const title = (p.querySelector('input[data-field="title"]') as HTMLInputElement).value.trim();
      const excerpt = (p.querySelector('textarea[data-field="excerpt"]') as HTMLTextAreaElement).value;
      const content = (p.querySelector('textarea[data-field="content"]') as HTMLTextAreaElement).value;
      if (title) translations[code] = { title, excerpt, content };
    });
    return { slug: slugInput.value.trim().toLowerCase(), coverUrl: coverUrl.value || null, translations };
  };

  // ---- Submit ----
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    msg.hidden = true;
    const submitter = (e.submitter as HTMLButtonElement) ?? null;
    const action = submitter?.dataset.action ?? 'draft';
    const published = action === 'publish';
    const payload = gather();
    const body = JSON.stringify({ ...payload, published });
    try {
      const res = mode === 'new'
        ? await fetch('/api/posts', { method: 'POST', headers: { 'content-type': 'application/json' }, body })
        : await fetch(`/api/posts/${postId}`, { method: 'PATCH', headers: { 'content-type': 'application/json' }, body });
      const data = await res.json().catch(() => ({}));
      if (!res.ok) { showErr(data.error ?? 'posts.error.failed'); return; }
      window.location.href = back;
    } catch (err) {
      showErr('posts.error.failed');
    }
  });

  // ---- Delete (edit only) ----
  const delBtn = document.getElementById('delete-btn') as HTMLButtonElement | null;
  delBtn?.addEventListener('click', async () => {
    if (!confirm(i18n['confirm-delete'] ?? '')) return;
    delBtn.disabled = true;
    try {
      const res = await fetch(`/api/posts/${postId}`, { method: 'DELETE' });
      if (res.ok) { window.location.href = back; return; }
      showErr('posts.error.failed');
      delBtn.disabled = false;
    } catch (err) {
      showErr('posts.error.failed');
      delBtn.disabled = false;
    }
  });
</script>

<style>
  .editor { max-width: 48rem; padding-block: 2rem; }
  .editor-head h1 { margin: 0; display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap; }
  .badge {
    font-size: 0.68rem;
    font-weight: 600;
    padding: 0.12rem 0.5rem;
    border-radius: 999px;
    border: 1px solid var(--color-border);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    vertical-align: middle;
  }
  .badge-draft { color: var(--color-muted); }
  .badge-pub {
    color: #15803d;
    border-color: color-mix(in srgb, #15803d 40%, transparent);
    background: color-mix(in srgb, #15803d 10%, transparent);
  }
  :root.dark .badge-pub {
    color: #86efac;
    border-color: color-mix(in srgb, #86efac 40%, transparent);
  }
  .subtitle { color: var(--color-muted); margin: 0.25rem 0 1.5rem; }
  .cover-field { margin-bottom: 1.25rem; }
  .cover-row { display: flex; align-items: flex-start; gap: 0.75rem; flex-wrap: wrap; }
  .cover-preview {
    width: 8rem;
    height: 4.5rem;
    border-radius: var(--radius-sm);
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .cover-preview img { width: 100%; height: 100%; object-fit: cover; }
  .cover-fallback { color: var(--color-muted); font-size: 1.5rem; }
  .cover-controls { display: flex; flex-direction: column; gap: 0.5rem; align-items: flex-start; }
  .slug-row { display: flex; gap: 0.5rem; }
  .slug-row input { flex: 1; }
  .hint { color: var(--color-muted); font-size: 0.8rem; margin: 0.25rem 0 0; }
  .tabs {
    display: flex;
    gap: 0.25rem;
    margin: 1.5rem 0 0;
    border-bottom: 1px solid var(--color-border);
  }
  .tab {
    appearance: none;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    padding: 0.5rem 0.9rem;
    color: var(--color-muted);
    font: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
  }
  .tab:hover { color: var(--color-text); }
  .tab.active { color: var(--color-text); border-bottom-color: var(--color-accent); }
  .lang-panel { border: none; padding: 0; margin: 1rem 0 0; }
  .lang-panel.hidden { display: none; }
  .lang-panel .field:last-child { margin-bottom: 0; }
  textarea.mono { font-family: var(--font-mono); font-size: 0.9rem; min-height: 18rem; }
  .action-row { display: flex; gap: 0.5rem; flex-wrap: wrap; align-items: center; }
  .action-row .del { margin-left: auto; border-color: color-mix(in srgb, #b91c1c 40%, transparent); color: #b91c1c; }
  .action-row .del:hover { background: color-mix(in srgb, #b91c1c 10%, transparent); }
  :root.dark .action-row .del { color: #fca5a5; border-color: color-mix(in srgb, #fca5a5 40%, transparent); }
</style>
