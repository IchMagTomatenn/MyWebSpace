---
/**
 * Hero-3D-Szene.
 *
 * Rendert einen Canvas mit einem distortierten Wireframe-Icosahedron, der
 * langsam rotiert, auf die Maus reagiert (Kamera-Parallax + dezent
 * Beschleunigung) und die Akzentfarbe der Seite übernimmt. Beim Scrollen
 * parallaxt die Kamera leicht nach unten.
 *
 * Three.js wird lazily via esm.sh geladen (kein Build-Bundle-Aufschlag,
 * kein npm-Paket). Schlägt der Import fehl (Offline, alter Browser) oder
 * ist `prefers-reduced-motion` aktiv, bleibt der Canvas unsichtbar — die
 * Seite funktioniert auch ohne ihn vollständig.
 *
 * Die Komponente ist rein dekorativ (`aria-hidden`); Inhalte liegen im
 * Vordergrund und bleiben barrierefrei.
 */
---

<canvas id="scene3d" class="scene3d" aria-hidden="true"></canvas>

<script is:inline type="module">
  (async () => {
    const canvas = document.getElementById('scene3d');
    if (!canvas) return;

    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Skip on tiny screens — the scene would be invisible behind stacked text.
    if (reduced || window.innerWidth < 640) {
      canvas.style.display = 'none';
      return;
    }

    let THREE;
    try {
      THREE = await import('https://esm.sh/three@0.160.0');
    } catch (e) {
      console.warn('[scene3d] three failed to load:', e);
      canvas.style.display = 'none';
      return;
    }

    // Theme-aware accent color (read live so dark/light switch picks it up).
    const accent = () => {
      const v = getComputedStyle(document.documentElement)
        .getPropertyValue('--color-accent')
        .trim();
      return v || '#dc2626';
    };
    const accent2 = () => {
      const v = getComputedStyle(document.documentElement)
        .getPropertyValue('--color-accent-hover')
        .trim();
      return v || '#f87171';
    };

    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance',
    });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(45, 1, 0.1, 100);
    camera.position.set(0, 0, 5.2);

    // --- Geometry + shader-distorted wireframe ----------------------------
    const geo = new THREE.IcosahedronGeometry(1.55, 18);

    const uniforms = {
      uTime: { value: 0 },
      uColor: { value: new THREE.Color(accent()) },
      uColor2: { value: new THREE.Color(accent2()) },
      uIntensity: { value: 0.32 },
    };

    const noiseGLSL = `
      vec3 mod289(vec3 x){return x-floor(x*(1.0/289.0))*289.0;}
      vec4 mod289(vec4 x){return x-floor(x*(1.0/289.0))*289.0;}
      vec4 permute(vec4 x){return mod289(((x*34.0)+1.0)*x);}
      vec4 taylorInvSqrt(vec4 r){return 1.79284291400159-0.85373472095314*r;}
      float snoise(vec3 v){
        const vec2 C=vec2(1.0/6.0,1.0/3.0); const vec4 D=vec4(0.0,0.5,1.0,2.0);
        vec3 i=floor(v+dot(v,C.yyy)); vec3 x0=v-i+dot(i,C.xxx);
        vec3 g=step(x0.yzx,x0.xyz); vec3 l=1.0-g;
        vec3 i1=min(g.xyz,l.zxy); vec3 i2=max(g.xyz,l.zxy);
        vec3 x1=x0-i1+C.xxx; vec3 x2=x0-i2+C.yyy; vec3 x3=x0-D.yyy;
        i=mod289(i);
        vec4 p=permute(permute(permute(i.z+vec4(0.0,i1.z,i2.z,1.0))
          +i.y+vec4(0.0,i1.y,i2.y,1.0))+i.x+vec4(0.0,i1.x,i2.x,1.0));
        float n_=0.142857142857; vec3 ns=n_*D.wyz-D.xzx;
        vec4 j=p-49.0*floor(p*ns.z*ns.z);
        vec4 x_=floor(j*ns.z); vec4 y_=floor(j-7.0*x_);
        vec4 x=x_*ns.x+ns.yyyy; vec4 y=y_*ns.x+ns.yyyy;
        vec4 h=1.0-abs(x)-abs(y);
        vec4 b0=vec4(x.xy,y.xy); vec4 b1=vec4(x.zw,y.zw);
        vec4 s0=floor(b0)*2.0+1.0; vec4 s1=floor(b1)*2.0+1.0;
        vec4 sh=-step(h,vec4(0.0));
        vec4 a0=b0.xzyw+s0.xzyw*sh.xxyy; vec4 a1=b1.xzyw+s1.xzyw*sh.zzww;
        vec3 p0=vec3(a0.xy,h.x); vec3 p1=vec3(a0.zw,h.y);
        vec3 p2=vec3(a1.xy,h.z); vec3 p3=vec3(a1.zw,h.w);
        vec4 norm=taylorInvSqrt(vec4(dot(p0,p0),dot(p1,p1),dot(p2,p2),dot(p3,p3)));
        p0*=norm.x; p1*=norm.y; p2*=norm.z; p3*=norm.w;
        vec4 m=max(0.6-vec4(dot(x0,x0),dot(x1,x1),dot(x2,x2),dot(x3,x3)),0.0); m=m*m;
        return 42.0*dot(m*m,vec4(dot(p0,x0),dot(p1,x1),dot(p2,x2),dot(p3,x3)));
      }`;

    const material = new THREE.ShaderMaterial({
      uniforms,
      transparent: true,
      wireframe: true,
      vertexShader: `
        uniform float uTime; uniform float uIntensity;
        varying vec3 vNormal; varying float vDistort;
        ${noiseGLSL}
        void main(){
          vec3 pos = position;
          float n = snoise(pos * 1.1 + uTime * 0.28);
          float n2 = snoise(pos * 2.3 - uTime * 0.18);
          vDistort = n + n2 * 0.35;
          pos += normal * vDistort * uIntensity;
          vNormal = normal;
          gl_Position = projectionMatrix * modelViewMatrix * vec4(pos, 1.0);
        }`,
      fragmentShader: `
        uniform vec3 uColor; uniform vec3 uColor2;
        varying vec3 vNormal; varying float vDistort;
        void main(){
          float t = vDistort * 0.5 + 0.5;
          vec3 col = mix(uColor, uColor2, clamp(t, 0.0, 1.0));
          float fres = pow(1.0 - clamp(dot(vNormal, vec3(0.0, 0.0, 1.0)), 0.0, 1.0), 2.0);
          col += fres * 0.55;
          gl_FragColor = vec4(col, 0.85);
        }`,
    });

    const wire = new THREE.Mesh(geo, material);
    scene.add(wire);

    // --- Glowing points overlay (additive blend) -------------------------
    const pointsMat = new THREE.PointsMaterial({
      size: 0.025,
      color: 0xffffff,
      transparent: true,
      opacity: 0.55,
      blending: THREE.AdditiveBlending,
      depthWrite: false,
      sizeAttenuation: true,
    });
    const points = new THREE.Points(geo, pointsMat);
    scene.add(points);

    // --- Resize -----------------------------------------------------------
    const resize = () => {
      const r = canvas.getBoundingClientRect();
      renderer.setSize(r.width, r.height, false);
      camera.aspect = r.width / Math.max(1, r.height);
      camera.updateProjectionMatrix();
    };
    resize();
    window.addEventListener('resize', resize, { passive: true });

    // --- Pointer parallax -------------------------------------------------
    const target = { x: 0, y: 0, px: 0, py: 0 };
    window.addEventListener(
      'pointermove',
      (e) => {
        target.px = (e.clientX / window.innerWidth) * 2 - 1;
        target.py = (e.clientY / window.innerHeight) * 2 - 1;
      },
      { passive: true },
    );

    // --- Re-pick accent when theme toggles --------------------------------
    const themeObserver = new MutationObserver(() => {
      uniforms.uColor.value.set(accent());
      uniforms.uColor2.value.set(accent2());
    });
    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['class'],
    });

    // Pause when the hero scrolls out of view (saves battery).
    let visible = true;
    const io = new IntersectionObserver(
      ([entry]) => (visible = entry.isIntersecting),
      { threshold: 0.01 },
    );
    io.observe(canvas);

    // --- Animation loop ---------------------------------------------------
    const clock = new THREE.Clock();
    const lerp = (a, b, t) => a + (b - a) * t;
    const tick = () => {
      if (visible) {
        const t = clock.getElapsedTime();
        uniforms.uTime.value = t;

        target.x = lerp(target.x, target.px * 0.9, 0.05);
        target.y = lerp(target.y, target.py * 0.6, 0.05);

        wire.rotation.y = t * 0.12 + target.x * 0.6;
        wire.rotation.x = Math.sin(t * 0.2) * 0.15 + target.y * 0.4;
        points.rotation.copy(wire.rotation);

        camera.position.x = target.x * 0.4;
        camera.position.y = -target.y * 0.3;
        camera.lookAt(0, 0, 0);

        renderer.render(scene, camera);
      }
      requestAnimationFrame(tick);
    };
    tick();

    // --- Tab visibility (full pause) --------------------------------------
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) clock.stop();
      else clock.start();
    });
  })();
</script>

<style>
  .scene3d {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    pointer-events: none;
    opacity: 0.9;
  }
</style>
