---
import { getLangFromUrl, t } from '../i18n/utils';
import { defaultLang } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url) ?? defaultLang;
const projectsHref = lang === defaultLang ? '/projects' : `/${lang}/projects`;
const blogHref = lang === defaultLang ? '/blog' : `/${lang}/blog`;
const contactHref = lang === defaultLang ? '/contact' : `/${lang}/contact`;

const skills = [
  { label: 'TypeScript', icon: 'ts' },
  { label: 'Astro', icon: 'astro' },
  { label: 'Node.js', icon: 'node' },
  { label: 'Python', icon: 'py' },
  { label: 'Docker', icon: 'docker' },
  { label: 'Git', icon: 'git' },
];
---

<section class="hero">
  <p class="greeting">{t(lang, 'home.hero.greeting')}</p>
  <h1>{t(lang, 'home.hero.name')}</h1>
  <p class="lead">{t(lang, 'home.hero.subtitle')}</p>
  <div class="cta">
    <a class="btn btn-primary" href={projectsHref}>
      {t(lang, 'home.cta.projects')}
    </a>
    <a class="btn btn-ghost" href={blogHref}>
      {t(lang, 'home.cta.blog')}
    </a>
    <a class="btn btn-ghost" href={contactHref}>
      {t(lang, 'home.cta.contact')}
    </a>
  </div>
</section>

<section class="about">
  <h2>{t(lang, 'home.about.title')}</h2>
  <p>{t(lang, 'home.about.body')}</p>
</section>

<section class="skills">
  <h2>{t(lang, 'home.skills.title')}</h2>
  <p class="skills-subtitle">{t(lang, 'home.skills.subtitle')}</p>
  <ul class="skill-list">
    {
      skills.map((skill) => (
        <li class="skill">
          <span class="skill-badge">{skill.label}</span>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .hero {
    padding-block: clamp(3rem, 10vw, 6rem) 2rem;
    text-align: center;
  }
  .greeting {
    color: var(--color-muted);
    font-size: 1.05rem;
    margin: 0 0 0.25rem;
  }
  .hero h1 {
    font-size: clamp(2.25rem, 6vw, 4rem);
    margin: 0 0 1rem;
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  .lead {
    font-size: 1.125rem;
    color: var(--color-muted);
    max-width: 40rem;
    margin-inline: auto;
  }
  .cta {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-block;
    padding: 0.65rem 1.2rem;
    border-radius: var(--radius);
    font-weight: 600;
    border: 1px solid transparent;
    transition: transform var(--transition),
      background-color var(--transition), border-color var(--transition);
  }
  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
  }
  .btn-ghost {
    border-color: var(--color-border);
    color: var(--color-text);
  }
  .btn-ghost:hover {
    border-color: var(--color-accent);
  }

  .about,
  .skills {
    margin-top: 3.5rem;
  }
  .about h2,
  .skills h2 {
    font-size: 1.5rem;
    margin: 0 0 0.75rem;
  }
  .about p {
    color: var(--color-muted);
    max-width: 42rem;
  }
  .skills-subtitle {
    color: var(--color-muted);
    margin: 0 0 1.25rem;
  }
  .skill-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .skill-badge {
    display: inline-block;
    padding: 0.4rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-surface);
    font-size: 0.9rem;
    color: var(--color-text);
    transition: border-color var(--transition),
      background-color var(--transition);
  }
  .skill-badge:hover {
    border-color: var(--color-accent);
  }
</style>
