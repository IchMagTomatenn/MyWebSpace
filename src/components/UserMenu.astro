---
// Conditional account menu for the header.
// - Logged out → Login / Register links.
// - Logged in  → Dashboard link + name + Admin link (admins) + Log out button.
// `Astro.locals.user` is populated by `src/middleware.ts`. Until then it is
// `null`, so the logged-out view is shown.
import { getLangFromUrl, t } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';

const lang: Lang = getLangFromUrl(Astro.url) ?? defaultLang;
const l = (path: string) => (lang === defaultLang ? path : `/${lang}${path}`);

const user = Astro.locals.user;
const homeHref = lang === defaultLang ? '/' : `/${lang}`;
---

{
  user ? (
    <div class="user-menu">
      <a href={l('/dashboard')} class="user-name" aria-label={t(lang, 'nav.dashboard')}>
        <span class="avatar" aria-hidden="true">
          {user.avatarUrl ? (
            <img src={user.avatarUrl} alt="" width="24" height="24" />
          ) : (
            <span class="avatar-fallback">{user.name.slice(0, 1).toUpperCase()}</span>
          )}
        </span>
        <span class="name">{user.name}</span>
      </a>
      {user.role === 'admin' && (
        <a href={l('/admin')} class="admin-link">{t(lang, 'nav.admin')}</a>
      )}
      <button id="logout-btn" class="logout-btn" type="button">
        {t(lang, 'nav.logout')}
      </button>
    </div>
  ) : (
    <div class="user-menu">
      <a href={l('/login')} class="auth-link">{t(lang, 'nav.login')}</a>
      <a href={l('/register')} class="auth-link auth-link-primary">{t(lang, 'nav.register')}</a>
    </div>
  )
}

<span id="user-menu-i18n" class="visually-hidden" data-home={homeHref}></span>

<script>
  import { authClient } from '../lib/auth-client';
  const btn = document.getElementById('logout-btn');
  if (btn) {
    btn.addEventListener('click', async () => {
      try {
        await authClient.signOut();
      } catch (e) {
        /* ignore — proceed to home regardless */
      }
      const home = document.getElementById('user-menu-i18n')!.dataset.home;
      window.location.href = home || '/';
    });
  }
</script>

<style>
  .user-menu {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .user-name {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.25rem 0.5rem;
    border-radius: var(--radius);
    color: var(--color-text);
    font-size: 0.9rem;
  }
  .user-name:hover {
    text-decoration: none;
    background: var(--color-surface);
  }
  .avatar {
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 999px;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .avatar-fallback {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-muted);
  }
  .name {
    max-width: 8rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .admin-link {
    font-size: 0.8rem;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    padding: 0.2rem 0.45rem;
    border-radius: var(--radius);
  }
  .logout-btn {
    font: inherit;
    font-size: 0.8rem;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    background: transparent;
    padding: 0.25rem 0.55rem;
    border-radius: var(--radius);
    cursor: pointer;
  }
  .logout-btn:hover {
    color: var(--color-text);
    border-color: var(--color-accent);
  }
  .auth-link {
    font-size: 0.9rem;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }
  .auth-link:hover {
    text-decoration: none;
    border-color: var(--color-accent);
  }
  .auth-link-primary {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
    border-color: transparent;
  }
  .auth-link-primary:hover {
    opacity: 0.9;
  }
  @media (max-width: 640px) {
    .name {
      display: none;
    }
  }
</style>
