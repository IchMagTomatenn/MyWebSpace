---
import { getLangFromUrl, t } from '../i18n/utils';
import { defaultLang, type Lang } from '../i18n/ui';
import { siteConfig } from '../config';
import SocialLinks from './SocialLinks.astro';

const lang: Lang = getLangFromUrl(Astro.url) ?? defaultLang;
const endpoint = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT as string | undefined;
const mailto = `mailto:${siteConfig.email}`;
---

<section class="contact-head">
  <h1>{t(lang, 'contact.title')}</h1>
  <p class="lead">{t(lang, 'contact.subtitle')}</p>
</section>

<div class="contact-grid">
  {
    endpoint ? (
      <form
        class="contact-form"
        data-endpoint={endpoint}
        data-sending={t(lang, 'contact.form.sending')}
        data-success={t(lang, 'contact.form.success')}
        data-error={t(lang, 'contact.form.error')}
        action={endpoint}
        method="POST"
        novalidate
      >
        <div class="field">
          <label for="name">{t(lang, 'contact.form.name')}</label>
          <input
            id="name"
            name="name"
            type="text"
            placeholder={t(lang, 'contact.form.name.placeholder')}
            autocomplete="name"
            required
          />
        </div>
        <div class="field">
          <label for="email">{t(lang, 'contact.form.email')}</label>
          <input
            id="email"
            name="email"
            type="email"
            placeholder={t(lang, 'contact.form.email.placeholder')}
            autocomplete="email"
            required
          />
        </div>
        <div class="field">
          <label for="message">{t(lang, 'contact.form.message')}</label>
          <textarea
            id="message"
            name="message"
            rows="6"
            placeholder={t(lang, 'contact.form.message.placeholder')}
            required
          />
        </div>
        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            {t(lang, 'contact.form.submit')}
          </button>
          <p class="status" role="status" aria-live="polite" hidden></p>
        </div>
      </form>
    ) : (
      <div class="contact-fallback">
        <h2>{t(lang, 'contact.form.fallback.title')}</h2>
        <p>{t(lang, 'contact.form.fallback.body')}</p>
        <a class="btn btn-primary" href={mailto}>
          {t(lang, 'contact.form.fallback.button')}
        </a>
      </div>
    )
  }

  <aside class="contact-direct">
    <h2>{t(lang, 'contact.direct.title')}</h2>
    <SocialLinks />
  </aside>
</div>

<script is:inline>
  (function () {
    var form = document.querySelector('.contact-form');
    if (!form) return;
    var status = form.querySelector('.status');
    var submit = form.querySelector('button[type="submit"]');
    var sendText = submit ? submit.textContent : '';
    var sendingText = form.getAttribute('data-sending') || 'Sending…';

    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }
      var data = new FormData(form);
      if (submit) {
        submit.disabled = true;
        submit.textContent = sendingText;
      }
      if (status) {
        status.hidden = false;
        status.textContent = '';
        status.className = 'status';
      }
      fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      })
        .then(function (res) {
          if (res.ok) {
            if (status) {
              status.textContent = form.getAttribute('data-success') || '';
              status.classList.add('ok');
            }
            form.reset();
          } else {
            throw new Error('Bad response');
          }
        })
        .catch(function () {
          if (status) {
            status.textContent = form.getAttribute('data-error') || '';
            status.classList.add('err');
          }
        })
        .finally(function () {
          if (submit) {
            submit.disabled = false;
            submit.textContent = sendText;
          }
        });
    });
  })();
</script>

<style>
  .contact-head {
    padding-block: 2rem 1.5rem;
  }
  .contact-head h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }
  .lead {
    color: var(--color-muted);
    margin: 0;
    max-width: 36rem;
  }

  .contact-grid {
    display: grid;
    gap: 2.5rem;
    grid-template-columns: minmax(0, 1fr) 18rem;
    align-items: start;
  }
  @media (max-width: 720px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .field label {
    font-size: 0.9rem;
    font-weight: 600;
  }
  .field input,
  .field textarea {
    font: inherit;
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-bg);
    color: var(--color-text);
    transition: border-color var(--transition), box-shadow var(--transition);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 25%, transparent);
  }
  .field textarea {
    resize: vertical;
    min-height: 8rem;
  }

  .form-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }
  .btn {
    display: inline-block;
    padding: 0.65rem 1.2rem;
    border-radius: var(--radius);
    font-weight: 600;
    border: 1px solid transparent;
    cursor: pointer;
    transition: transform var(--transition), background-color var(--transition),
      border-color var(--transition);
  }
  .btn:hover {
    text-decoration: none;
    transform: translateY(-1px);
  }
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-accent-contrast);
  }
  .btn-primary:disabled {
    opacity: 0.6;
    cursor: progress;
    transform: none;
  }
  .status {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
  }
  .status.ok {
    color: #16a34a;
  }
  .status.err {
    color: #dc2626;
  }

  .contact-fallback {
    padding: 1.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
  }
  .contact-fallback h2 {
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
  }
  .contact-fallback p {
    color: var(--color-muted);
    margin: 0 0 1rem;
  }

  .contact-direct h2 {
    font-size: 1.15rem;
    margin: 0 0 0.75rem;
  }
</style>
