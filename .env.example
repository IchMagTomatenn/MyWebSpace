# ----------------------------------------------------------------------------
# Developer Portal environment variables.
# Copy to .env for local development. In production these are set as Railway
# service variables. See README.md "Environment-Variablen (Referenz)".
# ----------------------------------------------------------------------------

# Public base URL of the site (used for absolute links in emails and OAuth
# callbacks). In dev this defaults to http://localhost:4321.
PUBLIC_SITE_URL=http://localhost:4321

# PostgreSQL connection string. Local Docker example:
#   docker run --name mywebspace-db -e POSTGRES_PASSWORD=dev -p 5432:5432 -d postgres:16
# DATABASE_URL=postgresql://postgres:dev@localhost:5432/mywebspace
DATABASE_URL=

# Better Auth: secret used to sign sessions. Generate a long random string, e.g.
#   openssl rand -base64 32
BETTER_AUTH_SECRET=

# Resend (transactional email): API key for verification & password-reset mails.
RESEND_API_KEY=
# Sender address for transactional emails.
EMAIL_FROM=no-reply@j-bot.net

# E-mail of the platform owner. The account registered with this address
# receives the `admin` role automatically.
ADMIN_EMAIL=ubztomaten@gmail.com

# Directory for uploaded files (avatars, covers). Defaults:
#   dev: ./uploads   |   prod: /data/uploads (Railway volume)
# UPLOAD_DIR=./uploads

# --- Optional: social login (Google) ---
# Set both to enable "Sign in with Google".
# Callback URL: ${PUBLIC_SITE_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional: social login (GitHub) ---
# Set both to enable "Sign in with GitHub".
# Callback URL: ${PUBLIC_SITE_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
