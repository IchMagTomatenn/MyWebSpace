# Astro frontend environment variables.
# Copy to .env and adjust for local development. In production these are set
# as Railway service variables (see remark42/README.md).

# Public URL of the Remark42 comment service backing the guestbook.
# Leave empty in development to render the guestbook fallback card.
PUBLIC_REMARK42_HOST=
PUBLIC_REMARK42_SITE_ID=mywebspace
