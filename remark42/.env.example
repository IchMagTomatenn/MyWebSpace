# Copy to .env and fill in real values before running `docker compose up`.
SECRET=change-me-to-a-long-random-string
ADMIN_PASS=change-me-admin-password
ADMIN_SHARED_ID=admin
ADMIN_SHARED_EMAIL=admin@example.com

# OAuth providers – register a GitHub/Google OAuth app pointed at
# http://localhost:8081/auth/<provider>/callback and paste the keys here.
AUTH_GITHUB_CID=
AUTH_GITHUB_CSEC=
AUTH_GOOGLE_CID=
AUTH_GOOGLE_CSEC=

# Public URL of the local Remark42 instance.
REMARK42_PUBLIC_URL=http://localhost:8081
