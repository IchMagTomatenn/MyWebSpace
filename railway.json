{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node ./dist/server/entry.mjs",
    "healthcheckPath": "/",
    "healthcheckTimeout": 30,
    "restartPolicyMaxRetries": 3
  }
}
