# Deployed to Railway as the "astro-frontend" service.
# Build & run the Astro static site via the Dockerfile (Caddy serving ./dist).

[deploy]
# Railway builds the Dockerfile at repo root and runs Caddy on $PORT.
startCommand = "caddy run --config /etc/caddy/Caddyfile --adapter caddyfile"
healthcheckPath = "/"
healthcheckTimeout = 30

# Multiplier applied to the build's memory/cpu allowance.
[deploy.restartPolicy]
maxRetries = 3
